{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tanaghom.local/contracts/phase7/skill-registry.v1.schema.json",
  "title": "Tanaghom Skill Registry recovery contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "export_policy", "skills"],
  "properties": {
    "contract_version": { "const": "tanaghom.skill-registry.v1" },
    "export_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "instructions_and_references_only",
        "customer_executable_scripts_allowed",
        "credentials_allowed",
        "runtime_authority"
      ],
      "properties": {
        "format": { "const": "agent-skills-compatible" },
        "instructions_and_references_only": { "const": true },
        "customer_executable_scripts_allowed": { "const": false },
        "credentials_allowed": { "const": false },
        "runtime_authority": { "const": false }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/skill" }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "stringSet": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120,
        "not": { "pattern": "(^|[.:/_-])(all|any)([.:/_-]|$)|\\*" }
      }
    },
    "permissionManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data_domains", "integrations", "channels", "operations"],
      "properties": {
        "data_domains": { "$ref": "#/$defs/stringSet" },
        "integrations": { "$ref": "#/$defs/stringSet" },
        "channels": { "$ref": "#/$defs/stringSet" },
        "operations": {
          "allOf": [
            { "$ref": "#/$defs/stringSet" },
            { "type": "array", "minItems": 1 }
          ]
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role_code", "worker_code"],
      "properties": {
        "role_code": { "$ref": "#/$defs/slug" },
        "worker_code": { "$ref": "#/$defs/slug" }
      }
    },
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "number",
        "lifecycle_state",
        "instructions",
        "input_schema_ref",
        "output_schema_ref",
        "risk_class",
        "side_effect_class",
        "permission_manifest",
        "integration_requirements",
        "executor",
        "package_path",
        "content_hash",
        "tool_schema_hash",
        "published_at",
        "audit_provenance"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "number": { "type": "integer", "minimum": 1 },
        "lifecycle_state": {
          "enum": ["draft", "validated", "published", "deprecated", "retired"]
        },
        "instructions": { "type": "string", "minLength": 20, "maxLength": 5000 },
        "input_schema_ref": {
          "type": "string",
          "pattern": "^packages/contracts/schemas/phase[0-9a-z]+/[a-z0-9-]+\\.v[1-9][0-9]*\\.schema\\.json$"
        },
        "output_schema_ref": {
          "type": "string",
          "pattern": "^packages/contracts/schemas/phase[0-9a-z]+/[a-z0-9-]+\\.v[1-9][0-9]*\\.schema\\.json$"
        },
        "risk_class": { "enum": ["low", "medium", "high", "critical"] },
        "side_effect_class": {
          "enum": ["none", "read_only", "proposal_only", "internal_write", "external_write"]
        },
        "permission_manifest": { "$ref": "#/$defs/permissionManifest" },
        "integration_requirements": { "$ref": "#/$defs/stringSet" },
        "executor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "ref", "version"],
          "properties": {
            "type": {
              "enum": ["controlled_database_function", "private_gateway_operation", "pinned_n8n_workflow"]
            },
            "ref": { "$ref": "#/$defs/slug" },
            "version": { "type": "string", "pattern": "^v[1-9][0-9]*$" }
          }
        },
        "package_path": {
          "type": "string",
          "pattern": "^skills/platform/[a-z0-9-]+/SKILL\\.md$"
        },
        "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "tool_schema_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "published_at": { "type": "string", "format": "date-time" },
        "audit_provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "issue", "worker_code"],
          "properties": {
            "source": { "const": "phase7a-reconciliation" },
            "issue": { "const": 132 },
            "worker_code": { "$ref": "#/$defs/slug" }
          }
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "code",
        "name",
        "description",
        "owner_scope",
        "organization_id",
        "skill_class",
        "version",
        "bindings"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "code": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 3, "maxLength": 120 },
        "description": { "type": "string", "minLength": 20, "maxLength": 1000 },
        "owner_scope": { "enum": ["platform", "organization"] },
        "organization_id": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "skill_class": { "enum": ["knowledge", "read", "proposal", "action"] },
        "version": { "$ref": "#/$defs/version" },
        "bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/binding" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "owner_scope": { "const": "platform" } },
            "required": ["owner_scope"]
          },
          "then": { "properties": { "organization_id": { "type": "null" } } },
          "else": { "properties": { "organization_id": { "type": "string", "format": "uuid" } } }
        }
      ]
    }
  }
}
