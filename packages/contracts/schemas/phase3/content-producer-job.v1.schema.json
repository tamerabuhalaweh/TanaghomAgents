{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tanaghom.test/contracts/phase3/content-producer-job.v1.schema.json",
  "title": "Content Producer job v1",
  "type": "object", "additionalProperties": false,
  "required": ["contract_version", "job_id", "correlation_id", "campaign", "strategy", "max_items"],
  "properties": {
    "contract_version": { "const": "phase3.content-producer-job.v1" },
    "job_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "campaign": { "type": "object", "required": ["id", "name", "brief", "product_type", "target_audience"], "properties": { "id": { "type": "string", "format": "uuid" }, "name": { "type": "string", "minLength": 1 }, "brief": { "type": "string", "minLength": 1 }, "product_type": { "enum": ["camp", "book", "coaching_program", "course"] }, "target_audience": { "type": "object" } }, "additionalProperties": false },
    "strategy": { "type": "object", "required": ["id", "version", "positioning", "key_messages", "channels", "posting_cadence", "content_pillars"], "properties": { "id": { "type": "string", "format": "uuid" }, "version": { "type": "integer", "minimum": 1 }, "positioning": { "type": "string", "minLength": 1 }, "key_messages": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "channels": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "posting_cadence": { "type": "object" }, "content_pillars": { "type": "array", "minItems": 1, "items": { "type": "object" } } }, "additionalProperties": false },
    "max_items": { "type": "integer", "minimum": 1, "maximum": 12 },
    "regeneration": { "type": ["object", "null"], "additionalProperties": false, "required": ["parent_content_id", "generation", "channel", "content_type", "previous_draft", "rejection_reason"], "properties": { "parent_content_id": { "type": "string", "format": "uuid" }, "generation": { "type": "integer", "minimum": 2 }, "channel": { "type": "string", "minLength": 1 }, "content_type": { "enum": ["post", "reel_script", "ad_copy", "email"] }, "previous_draft": { "type": "string", "minLength": 1 }, "rejection_reason": { "type": "string", "minLength": 1 } } }
  }
}
