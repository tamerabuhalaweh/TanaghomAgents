{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tanaghom.test/contracts/phase3/content-producer-output.v1.schema.json",
  "title": "Content Producer output v1",
  "type": "object", "additionalProperties": false,
  "required": ["contract_version", "items"],
  "properties": {
    "contract_version": { "const": "phase3.content-producer-output.v1" },
    "items": {
      "type": "array", "minItems": 1, "maxItems": 12,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["channel", "content_type", "content_pillar", "draft_copy", "media_brief", "scheduled_time_suggestion"],
        "properties": {
          "channel": { "enum": ["instagram", "tiktok", "facebook", "linkedin", "youtube", "email", "whatsapp_status"] },
          "content_type": { "enum": ["post", "reel_script", "ad_copy", "email"] },
          "content_pillar": { "type": "string", "minLength": 1, "maxLength": 160 },
          "draft_copy": { "type": "string", "minLength": 1, "maxLength": 20000 },
          "media_brief": { "type": "string", "minLength": 1, "maxLength": 5000 },
          "scheduled_time_suggestion": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    }
  }
}
