{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tanaghom.test/contracts/phase5/conversation-summary.v1.schema.json",
  "title": "Bounded conversation summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "prompt_version", "language", "summary", "input_event_ids"],
  "properties": {
    "contract_version": { "const": "phase5.conversation-summary.v1" },
    "prompt_version": { "const": "phase5.conversation-summary.prompt.v1" },
    "language": { "enum": ["en", "ar"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "input_event_ids": { "type": "array", "minItems": 1, "maxItems": 12, "uniqueItems": true, "items": { "type": "string", "format": "uuid" } }
  }
}
