{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tanaghom.test/contracts/phase5g/quality-baseline-import.v1.schema.json",
  "title": "Tanaghom de-identified human baseline import v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "name", "source_hash", "period_start", "period_end", "versions", "pii_removed_attestation", "cases"],
  "properties": {
    "contract_version": { "const": "phase5g.quality-baseline-import.v1" },
    "name": { "type": "string", "minLength": 3, "maxLength": 160 },
    "source_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "period_start": { "type": "string", "format": "date-time" },
    "period_end": { "type": "string", "format": "date-time" },
    "versions": { "$ref": "#/$defs/versions" },
    "pii_removed_attestation": { "const": true },
    "cases": { "type": "array", "minItems": 1, "maxItems": 1000, "items": { "$ref": "#/$defs/case" } }
  },
  "$defs": {
    "versions": {
      "type": "object", "additionalProperties": false,
      "required": ["model", "prompt", "knowledge", "policy", "campaign"],
      "properties": { "model": { "type": "string", "minLength": 1 }, "prompt": { "type": "string", "minLength": 1 }, "knowledge": { "type": "string", "minLength": 1 }, "policy": { "type": "string", "minLength": 1 }, "campaign": { "type": "string", "minLength": 1 } }
    },
    "case": {
      "type": "object", "additionalProperties": false,
      "required": ["reference_hash", "language", "customer_message", "human_reply", "response_seconds", "qualified", "booked", "won", "handed_off", "opted_out", "complaint", "reviewed"],
      "properties": {
        "reference_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "language": { "type": "string", "minLength": 2, "maxLength": 20 },
        "customer_message": { "type": "string", "minLength": 1, "maxLength": 10000 },
        "human_reply": { "type": "string", "minLength": 1, "maxLength": 5000 },
        "response_seconds": { "type": "number", "minimum": 0, "maximum": 604800 },
        "qualified": { "type": "boolean" }, "booked": { "type": "boolean" }, "won": { "type": "boolean" },
        "handed_off": { "type": "boolean" }, "opted_out": { "type": "boolean" }, "complaint": { "type": "boolean" }, "reviewed": { "const": true }
      }
    }
  }
}
