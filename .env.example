# Local development placeholders only. Never commit real values.
APP_ENV=development
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://tanaghom:tanaghom@localhost:5432/tanaghom_agents
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5432/tanaghom_agents_test
N8N_BASE_URL=http://localhost:5678

# Supabase is inspected server-side only. Keep real values in an untracked
# environment file or secret store. Browser code must never receive secret keys.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# n8n and application ingress. Credential objects are created in n8n itself;
# exports retain placeholder credential IDs only.
N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=
WEBHOOK_URL=
PUBLIC_WEBHOOK_BASE=
WEBHOOK_AGENT1_PATH=agent-1-campaign-strategist
WEBHOOK_AGENT2_PATH=agent-2-content-producer
WEBHOOK_AGENT3_PATH=agent-3-publisher
WEBHOOK_AGENT3_MONITOR_PATH=agent-3-performance-monitor
WEBHOOK_AGENT4_PATH=agent-4-sales-crm
WEBHOOK_APPROVAL_PATH=content-approval
INTERNAL_WEBHOOK_SECRET=

# Auth/session placeholders. Shared Basic Auth is a legacy compatibility input,
# not the target Phase 2 authentication model.
DASHBOARD_PORT=3000
DASHBOARD_AUTH_USER=
DASHBOARD_AUTH_PASSWORD=
SESSION_SECRET=

# OpenAI-compatible Gemma endpoint and versioned model selectors.
GEMMA_API_BASE_URL=
OPENAI_BASE_URL=
OPENAI_API_KEY=
LLM_MODEL=
LLM_MODEL_STRATEGY=
LLM_MODEL_CONTENT=

# Added only when their integration phase begins. Keep outbound actions disabled
# until the corresponding staging acceptance gate is approved.
POSTIZ_API_BASE_URL=
POSTIZ_API_BASE=
POSTIZ_HANDOFF_ENABLED=false
POSTIZ_API_KEY=
GHL_API_BASE_URL=
GHL_API_BASE=
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
GHL_DEFAULT_WORKFLOW_ID=
BOOKING_LINK=
ALLOW_STAGING_PUBLISH=false

# Schedules and operator notifications.
PERFORMANCE_SYNC_CRON=
CONTENT_CADENCE_CRON=
MAX_SYNC_FAILURES_BEFORE_ALERT=3
ALERT_WEBHOOK_URL=
SALES_REPORT_WEBHOOK_URL=
